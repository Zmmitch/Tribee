{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build -w packages/api"
  },
  "deploy": {
    "startCommand": "npm run start -w packages/api",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
